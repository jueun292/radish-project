# ─────────────────────────── Python ───────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ──────────────────── Virtual environment ─────────────────────
.venv/
venv/
env/

# ──────────────────────── OS / editor ─────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# ════════════════ Dataset (NOT committed — see README §데이터) ════════════════
# The AI-Hub radish dataset (~37 GB) must be obtained separately and placed
# under data/. We keep only the helper scripts (data/*.py); everything else
# (zips, extracted images/labels, by_disease symlinks) is ignored.
data/*
!data/*.py

# ════════════════ Experiment outputs ════════════════
# Heavy artifacts are regenerated by training (see README §재현). We keep the
# small, reproduction-relevant files: metrics.json (results) and config.snapshot
# (frozen hyperparameters + environment) — both are tracked.
experiments/*/checkpoints/
experiments/*/predictions/
experiments/*/train.log

# ════════════════ Workspace ════════════════
# Kept (needed to reproduce): _workspace/specs/, _workspace/eval/*.py,
# _workspace/data/manifest_*.csv + data_card.md, launch_*.sh.
# Ignored: run logs and any previous-run snapshots.
_workspace/*.log
_workspace/launch_exp_*.log
_workspace/timing_*.log
_workspace/demo_server.log
_workspace/logs/
_workspace_prev/

# Stray checkpoint files anywhere
*.pt
*.pth
*.ckpt

# Temp
/tmp/
*.tmp
